# Docker — copy to .env.docker
SECRET_KEY=change-me-for-docker
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
CORS_ALLOWED_ORIGINS=http://localhost:4200
DATABASE_URL=postgres://cleanops:cleanops@db:5432/cleanops

# Serve uploads from the persistent media volume (use S3 for large-scale production)
SERVE_MEDIA=True

# Hide API docs in production-like Docker deploys
SERVE_API_DOCS=False

# Set to False if testing locally over plain HTTP with DEBUG=False
SECURE_SSL_REDIRECT=False
