# Development defaults — copy to .env
SECRET_KEY=change-me-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:4200,http://127.0.0.1:4200

# Optional: leave unset to use SQLite locally
# DATABASE_URL=postgres://user:password@localhost:5432/cleanops

# Serve uploaded files (avatars, task photos) through Django
SERVE_MEDIA=True

# Expose Swagger/ReDoc at /api/docs/ and /api/redoc/
SERVE_API_DOCS=True

# Production-only (ignored when DEBUG=True)
# SECURE_SSL_REDIRECT=True
# SECURE_HSTS_SECONDS=31536000
